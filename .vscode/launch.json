{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Aquiis.WebUI",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/Aquiis.WebUI/Aquiis.WebUI.csproj",
      "program": "${workspaceFolder}/Aquiis.WebUI/bin/Debug/net9.0/Aquiis.WebUI.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Aquiis.WebUI",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5244;https://localhost:7244"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      },
      "preLaunchTask": "build"
    },
    {
      "name": "Launch Aquiis.WebUI (Production)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/Aquiis.WebUI/Aquiis.WebUI.csproj",
      "program": "${workspaceFolder}/Aquiis.WebUI/bin/Release/net9.0/Aquiis.WebUI.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Aquiis.WebUI",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Production",
        "ASPNETCORE_URLS": "http://localhost:5000;https://localhost:5001"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      },
      "preLaunchTask": "build-release"
    },
    {
      "name": "Attach to Aquiis.WebUI",
      "type": "dotnet",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
